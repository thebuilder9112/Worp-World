{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores basic user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Timestamp of the last login." }
      },
      "required": ["uid", "email"]
    },
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Publicly visible unit information for tactical coordination.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "lastLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "status": { "type": "string", "description": "Unit operational status." }
      },
      "required": ["uid"]
    },
    "RouteHistory": {
      "title": "Tactical Route History",
      "description": "Stores historical tactical routes calculated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who created the route." },
        "startPlace": { "type": "string", "description": "Starting location name." },
        "endPlace": { "type": "string", "description": "Destination location name." },
        "mode": { "type": "string", "description": "Transport mode used." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the route was calculated." },
        "distance": { "type": "number", "description": "Total distance in meters." }
      },
      "required": ["userId", "startPlace", "endPlace", "timestamp"]
    },
    "Share": {
      "title": "Share",
      "description": "Stores shared locations or routes for real-time tactical coordination.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who shared the location/route." },
        "type": { "type": "string", "enum": ["live", "location", "route"], "description": "The type of share." },
        "data": { "type": "object", "description": "The shared data (coordinates or points)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the share was created." },
        "expiresAt": { "type": "string", "format": "date-time", "description": "Optional expiration time." },
        "active": { "type": "boolean", "description": "Whether the share is currently active." }
      },
      "required": ["userId", "type", "data", "timestamp"]
    },
    "Alert": {
      "title": "Emergency Alert",
      "description": "Danger warnings, evacuation orders, and shelter information broadcasts.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Alert headline." },
        "message": { "type": "string", "description": "Alert details." },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"], "description": "Alert level." },
        "zone": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "radius": { "type": "number" }
          },
          "required": ["lat", "lng", "radius"]
        },
        "timestamp": { "type": "string", "format": "date-time", "description": "Alert broadcast time." },
        "senderId": { "type": "string", "description": "Sender user ID." },
        "active": { "type": "boolean", "description": "Is this alert active." }
      },
      "required": ["title", "message", "severity", "zone", "timestamp", "senderId"]
    },
    "Contact": {
      "title": "Trusted Contact",
      "description": "Another operator selected for private location sharing.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the contact." },
        "displayName": { "type": "string", "description": "Display name of the contact." },
        "email": { "type": "string", "format": "email", "description": "Email of the contact." },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL of the contact." },
        "sharedWith": { "type": "boolean", "description": "Whether the current user is sharing location with this contact." },
        "status": { "type": "string", "description": "Contact's tactical status." },
        "addedAt": { "type": "string", "format": "date-time", "description": "When the contact was added." }
      },
      "required": ["uid", "displayName", "email", "sharedWith"]
    },
    "OfflineRegion": {
      "title": "Offline Region",
      "description": "Metadata for pre-downloaded map regions for offline operations.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the downloaded region." },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "radius": { "type": "number" },
        "tileCount": { "type": "number", "description": "Number of cached tile files." },
        "downloadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "lat", "lng", "radius"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "RouteHistory",
      "description": "Tactical route history records."
    },
    "/users/{userId}/contacts/{contactId}": {
      "schema": "Contact",
      "description": "User's trusted contacts list."
    },
    "/users/{userId}/offline_regions/{regionId}": {
      "schema": "OfflineRegion",
      "description": "User's pre-downloaded offline regions metadata."
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Publicly visible tactical unit data."
    },
    "/shares/{shareId}": {
      "schema": "Share",
      "description": "Shared tactical data."
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Global crisis alert broadcasts."
    }
  }
}
